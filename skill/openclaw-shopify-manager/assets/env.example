# OpenClaw Shopify Manager runtime secrets
SHOPIFY_SHOP=example.myshopify.com
SHOPIFY_API_VERSION=2026-01
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_content,write_content,read_orders
SHOPIFY_PUBLIC_BASE_URL=https://YOUR-TAILSCALE-OR-DOMAIN/shopify-manager
SHOPIFY_REDIRECT_URI=https://YOUR-TAILSCALE-OR-DOMAIN/shopify-manager/shopify/callback
SHOPIFY_SERVER_HOST=127.0.0.1
SHOPIFY_SERVER_PORT=8787
SHOPIFY_MODE=require-confirmation-for-mutations
SHOPIFY_ACCESS_TOKEN=
